generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pgcrypto, uuid_ossp]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  LEADER
  EXECUTIVE
  TEAM
  ENTERPRISE
  LIFETIME
}

enum PillarType {
  HEART
  HOPE
  HEALTH
  HELP
}

enum AgentType {
  LIFE_COACH
  HEALTH_COACH
  PURPOSE_COACH
  RELATIONSHIP_COACH
  MENTAL_WELLNESS
  EXECUTIVE_COACH
  MEDITATION_COACH
  HAPPINESS_COACH
  SLEEP_COACH
  NUTRITION_COACH
  CAREER_COACH
  FINANCIAL_COACH
  SPIRITUAL_COACH
  SOCIAL_COACH
  CRISIS_SUPPORT
}

enum GoalStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum SessionStatus {
  ACTIVE
  ENDED
}

// ─── Core ─────────────────────────────────────────────────────────────────────

model User {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId     String           @unique @map("clerk_id")
  email       String           @unique
  firstName   String?          @map("first_name")
  lastName    String?          @map("last_name")
  imageUrl    String?          @map("image_url")
  tier        SubscriptionTier @default(FREE)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  profile              UserProfile?
  subscriptions        Subscription[]
  assessments          Assessment[]
  dailyScores          DailyScore[]
  lifeBlueprints       LifeBlueprint[]
  relationships        Relationship[]
  journalEntries       JournalEntry[]
  gratitudeEntries     GratitudeEntry[]
  goals                Goal[]
  healthProfile        HealthProfile?
  healthLogs           HealthLog[]
  habits               Habit[]
  impactProfile        ImpactProfile?
  volunteerActivities  VolunteerActivity[]
  aiSessions           AiSession[]
  aiInsights           AiInsight[]
  communityMembers     CommunityMember[]
  communityPosts       CommunityPost[]
  xp                   UserXp?
  notifications        Notification[]
  weeklyReports        WeeklyReport[]
  challengeParticipants ChallengeParticipant[]

  @@map("users")
}

model UserProfile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  bio           String?
  timezone      String    @default("UTC")
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  gender        String?
  occupation    String?
  primaryPillar PillarType? @map("primary_pillar")
  onboardingDone Boolean  @default(false) @map("onboarding_done")
  preferences   Json      @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Subscription {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String           @map("user_id") @db.Uuid
  tier              SubscriptionTier
  stripeSubId       String?          @unique @map("stripe_sub_id")
  razorpaySubId     String?          @unique @map("razorpay_sub_id")
  currentPeriodEnd  DateTime?        @map("current_period_end")
  cancelAtPeriodEnd Boolean          @default(false) @map("cancel_at_period_end")
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Happiness ────────────────────────────────────────────────────────────────

model Assessment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  heartScore  Float    @map("heart_score")
  hopeScore   Float    @map("hope_score")
  healthScore Float    @map("health_score")
  helpScore   Float    @map("help_score")
  totalScore  Float    @map("total_score")
  answers     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model DailyScore {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  date        DateTime @db.Date
  heartScore  Float    @map("heart_score")
  hopeScore   Float    @map("hope_score")
  healthScore Float    @map("health_score")
  helpScore   Float    @map("help_score")
  totalScore  Float    @map("total_score")
  mood        Int?
  energyLevel Int?     @map("energy_level")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_scores")
}

model LifeBlueprint {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  pillar      PillarType
  type        String
  content     Json
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("life_blueprints")
}

// ─── Heart ────────────────────────────────────────────────────────────────────

model Relationship {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  type        String
  closeness   Int      @default(5)
  lastContact DateTime? @map("last_contact")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions RelationshipInteraction[]

  @@map("relationships")
}

model RelationshipInteraction {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  relationshipId String   @map("relationship_id") @db.Uuid
  type           String
  quality        Int      @default(5)
  notes          String?
  occurredAt     DateTime @default(now()) @map("occurred_at")

  relationship Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)

  @@map("relationship_interactions")
}

model JournalEntry {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  title      String?
  content    String
  mood       Int?
  pillars    PillarType[]
  sentiment  Float?
  emotions   String[]
  themes     String[]
  aiAnalysis Json?      @map("ai_analysis")
  embedding  Unsupported("vector(1536)")?
  isPrivate  Boolean    @default(true) @map("is_private")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("journal_entries")
}

model GratitudeEntry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  items     String[]
  mood      Int?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gratitude_entries")
}

// ─── Hope ─────────────────────────────────────────────────────────────────────

model Goal {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  title       String
  description String?
  pillar      PillarType
  status      GoalStatus @default(ACTIVE)
  targetDate  DateTime?  @map("target_date") @db.Date
  progress    Float      @default(0)
  whyStatement String?   @map("why_statement")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones GoalMilestone[]
  checkIns   GoalCheckIn[]

  @@map("goals")
}

model GoalMilestone {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId      String   @map("goal_id") @db.Uuid
  title       String
  isCompleted Boolean  @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  dueDate     DateTime? @map("due_date") @db.Date
  sortOrder   Int      @default(0) @map("sort_order")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_milestones")
}

model GoalCheckIn {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId    String   @map("goal_id") @db.Uuid
  progress  Float
  note      String?
  mood      Int?
  createdAt DateTime @default(now()) @map("created_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_check_ins")
}

// ─── Health ───────────────────────────────────────────────────────────────────

model HealthProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  heightCm       Float?   @map("height_cm")
  weightKg       Float?   @map("weight_kg")
  targetWeightKg Float?   @map("target_weight_kg")
  sleepGoalHours Float    @default(8) @map("sleep_goal_hours")
  stepsGoal      Int      @default(10000) @map("steps_goal")
  waterGoalMl    Int      @default(2000) @map("water_goal_ml")
  conditions     String[]
  medications    String[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("health_profiles")
}

model HealthLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  date           DateTime @db.Date
  sleepHours     Float?   @map("sleep_hours")
  sleepQuality   Int?     @map("sleep_quality")
  stepsCount     Int?     @map("steps_count")
  waterMl        Int?     @map("water_ml")
  exerciseMin    Int?     @map("exercise_min")
  exerciseType   String?  @map("exercise_type")
  stressLevel    Int?     @map("stress_level")
  energyLevel    Int?     @map("energy_level")
  weightKg       Float?   @map("weight_kg")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("health_logs")
}

model Habit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  emoji       String   @default("⭐")
  pillar      PillarType
  frequency   String   @default("daily")
  targetCount Int      @default(1) @map("target_count")
  streak      Int      @default(0)
  bestStreak  Int      @default(0) @map("best_streak")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@map("habits")
}

model HabitLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  habitId   String   @map("habit_id") @db.Uuid
  date      DateTime @db.Date
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@map("habit_logs")
}

// ─── Help ─────────────────────────────────────────────────────────────────────

model ImpactProfile {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  totalHours      Float    @default(0) @map("total_hours")
  totalDonations  Float    @default(0) @map("total_donations")
  impactScore     Float    @default(0) @map("impact_score")
  causes          String[]
  skills          String[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("impact_profiles")
}

model VolunteerActivity {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  organization String
  role         String?
  hours        Float
  date         DateTime @db.Date
  cause        String?
  impact       String?
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("volunteer_activities")
}

// ─── AI ───────────────────────────────────────────────────────────────────────

model AiSession {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  agentType   AgentType     @map("agent_type")
  status      SessionStatus @default(ACTIVE)
  title       String?
  tokenCount  Int           @default(0) @map("token_count")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]
  memories AiMemory[]

  @@map("ai_sessions")
}

model AiMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String
  content   String
  tokens    Int?
  createdAt DateTime @default(now()) @map("created_at")

  session AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model AiMemory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  sessionId   String?   @map("session_id") @db.Uuid
  agentType   AgentType @map("agent_type")
  content     String
  importance  Float     @default(0.5)
  embedding   Unsupported("vector(1536)")?
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  session AiSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("ai_memories")
}

model AiInsight {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  pillar    PillarType
  title     String
  body      String
  score     Float?
  actionItems String[] @map("action_items")
  isRead    Boolean    @default(false) @map("is_read")
  createdAt DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}

// ─── Community ────────────────────────────────────────────────────────────────

model Community {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  isPublic    Boolean  @default(true) @map("is_public")
  memberCount Int      @default(0) @map("member_count")
  createdAt   DateTime @default(now()) @map("created_at")

  members CommunityMember[]
  posts   CommunityPost[]

  @@map("communities")
}

model CommunityMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String   @default("member")
  joinedAt    DateTime @default(now()) @map("joined_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@map("community_members")
}

model CommunityPost {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  content     String
  pillar      PillarType?
  likeCount   Int      @default(0) @map("like_count")
  replyCount  Int      @default(0) @map("reply_count")
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("community_posts")
}

model Challenge {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  pillar      PillarType
  emoji       String   @default("🎯")
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  rewardXp    Int      @default(100) @map("reward_xp")
  createdAt   DateTime @default(now()) @map("created_at")

  participants ChallengeParticipant[]

  @@map("challenges")
}

model ChallengeParticipant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challengeId String   @map("challenge_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  progress    Float    @default(0)
  completed   Boolean  @default(false)
  completedAt DateTime? @map("completed_at")
  joinedAt    DateTime @default(now()) @map("joined_at")

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@map("challenge_participants")
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model UserXp {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  totalXp      Int      @default(0) @map("total_xp")
  level        Int      @default(1)
  heartXp      Int      @default(0) @map("heart_xp")
  hopeXp       Int      @default(0) @map("hope_xp")
  healthXp     Int      @default(0) @map("health_xp")
  helpXp       Int      @default(0) @map("help_xp")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_xp")
}

// ─── Analytics ────────────────────────────────────────────────────────────────

model WeeklyReport {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  weekStart     DateTime @map("week_start") @db.Date
  avgHeart      Float    @map("avg_heart")
  avgHope       Float    @map("avg_hope")
  avgHealth     Float    @map("avg_health")
  avgHelp       Float    @map("avg_help")
  avgTotal      Float    @map("avg_total")
  narrative     String?
  topInsights   String[] @map("top_insights")
  actionItems   String[] @map("action_items")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@map("weekly_reports")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
