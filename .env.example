# ════════════════════════════════════════════════════════════
# SthirMind Environment Variables
# Copy to .env.local and fill in your values
# ════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://sthirmind:sthirmind_dev@localhost:5432/sthirmind

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=...
PINECONE_INDEX=sthirmind-memory

# ── Authentication (Clerk) ───────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/onboarding

# ── Payments ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_LEADER_MONTHLY=price_...
STRIPE_PRICE_EXECUTIVE_MONTHLY=price_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# ── Web App ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Search ───────────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev_master_key_change_in_prod

# ── Analytics ────────────────────────────────────────────────
POSTHOG_API_KEY=phc_...
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@sthirmind.in

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=https://...
GRAFANA_API_KEY=...

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here_min_32_chars
ALLOWED_ORIGINS=http://localhost:3000,https://sthirmind.hopecommonersfoundation.com
RATE_LIMIT_PER_MINUTE=100
